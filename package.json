{
  "name": "super_produc_mcp",
  "version": "1.0.0",
  "description": "Socket.IO-based MCP bridge for Super Productivity",
  "main": "dist/index.js",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "bun run build:server && bun run build:plugin",
    "build:server": "tsc",
    "build:plugin": "bun scripts/build-plugin.mjs",
    "docker:build": "docker build -t super-productivity-mcp .",
    "docker:run": "docker run --rm -p 3000:3000 --name super-productivity-mcp super-productivity-mcp",
    "start": "bun dist/index.js start",
    "dev": "bun --watch src/index.ts start",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "express": "^5.1.0",
    "figlet": "^1.11.0",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.3"
  }
}
